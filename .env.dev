# Environment Configuration
ENVIRONMENT=development

# Firebase Configuration
FIREBASE_CREDENTIALS_PATH=firebase-dev.json
FIREBASE_PROJECT_ID=attendrix-109cc
FIREBASE_DATABASE_URL=https://attendrix-109cc.firebaseio.com
USE_MOCK_FIREBASE=false

# Database Configuration (using SQLite for development)
DATABASE_URL=sqlite:///attendrix_dev.db
REDIS_URL=redis://localhost:6379/0

# Flask Configuration
SECRET_KEY=dev-secret-key-change-in-production
FLASK_ENV=development
FLASK_DEBUG=True

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Security Configuration
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=86400

# Rate Limiting
RATELIMIT_STORAGE_URL=redis://localhost:6379/1
RATELIMIT_DEFAULT=200 per day, 50 per hour

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,pdf,doc,docx

# Analytics and Monitoring
SENTRY_DSN=
LOG_LEVEL=DEBUG

# Geolocation Configuration
GOOGLE_GEOCODING_API_KEY=
DEFAULT_GEOLOCATION_RADIUS=100  # meters

# Attendance Configuration
DEFAULT_ATTENDANCE_THRESHOLD=75  # percentage
SESSION_TIMEOUT_MINUTES=15
MAX_LATE_MINUTES=10

# Cache Configuration
CACHE_TYPE=simple
CACHE_REDIS_URL=redis://localhost:6379/2

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/3
CELERY_RESULT_BACKEND=redis://localhost:6379/4
