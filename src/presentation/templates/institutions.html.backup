<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Institutions - Attendrix | Institutional Paperless Attendance System</title>
    <meta name="description" content="Manage institutions in the Attendrix system">
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/static/images/favicon.ico">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/landing.css') }}">
    
    <style>
        .institutions-container {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            padding-top: 100px;
            padding-bottom: 2rem;
        }
        
        .institutions-header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(102, 126, 234, 0.1);
        }
        
        .institutions-section {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(102, 126, 234, 0.1);
        }
        
        .section-title {
            color: #2c3e50;
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
        }
        
        .section-title i {
            color: #667eea;
            margin-right: 0.5rem;
        }
        
        .institution-card {
            background: white;
            border: 2px solid #e9ecef;
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: all 0.3s ease;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
        }
        
        .institution-card:hover {
            border-color: #667eea;
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.2);
        }
        
        .institution-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }
        
        .institution-name {
            font-size: 1.2rem;
            font-weight: 600;
            color: #2c3e50;
        }
        
        .institution-status {
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.875rem;
            font-weight: 500;
        }
        
        .status-active {
            background: rgba(40, 167, 69, 0.1);
            color: #28a745;
        }
        
        .status-inactive {
            background: rgba(220, 53, 69, 0.1);
            color: #dc3545;
        }
        
        .institution-details {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-bottom: 1rem;
        }
        
        .detail-item {
            display: flex;
            align-items: center;
        }
        
        .detail-label {
            font-weight: 500;
            color: #6c757d;
            margin-right: 0.5rem;
        }
        
        .detail-value {
            color: #2c3e50;
        }
        
        .institution-actions {
            display: flex;
            gap: 0.5rem;
        }
        
        .btn-institution {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 0.5rem 1rem;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.3s ease;
            box-shadow: 0 3px 10px rgba(102, 126, 234, 0.3);
        }
        
        .btn-institution:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
        
        .btn-outline {
            background: transparent;
            color: #667eea;
            border: 2px solid #667eea;
        }
        
        .btn-outline:hover {
            background: #667eea;
            color: white;
        }
        
        .btn-danger {
            background: #dc3545;
            color: white;
        }
        
        .btn-danger:hover {
            background: #c82333;
        }
        
        .profile-avatar-small {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.875rem;
            transition: transform 0.3s ease;
        }
        
        .profile-avatar-small:hover {
            transform: scale(1.1);
        }
        
        .dropdown-menu {
            border: 1px solid rgba(102, 126, 234, 0.1);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            padding: 0.5rem;
        }
        
        .dropdown-item {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
            color: #2c3e50;
        }
        
        .dropdown-item:hover {
            background: rgba(102, 126, 234, 0.1);
            color: #667eea;
        }
        
        .dropdown-divider {
            margin: 0.5rem 0;
            border-color: rgba(102, 126, 234, 0.1);
        }
        
        .alert {
            border-radius: 12px;
            border: none;
            padding: 1rem;
        }
        
        .alert-success {
            background: rgba(40, 167, 69, 0.1);
            color: #28a745;
        }
        
        .alert-danger {
            background: rgba(220, 53, 69, 0.1);
            color: #dc3545;
        }
    </style>
</head>
<body>
    <div class="institutions-container">
        <!-- Navigation -->
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
            <div class="container">
                <a class="navbar-brand" href="/">
                    <i class="fas fa-graduation-cap me-2"></i>
                    <strong>Attendrix</strong>
                </a>
                <div class="navbar-nav ms-auto">
                    <a class="nav-link" href="/dashboard">
                        <i class="fas fa-tachometer-alt me-1"></i>Dashboard
                    </a>
                    <a class="nav-link" href="/institutions">
                        <i class="fas fa-building me-1"></i>Institutions
                    </a>
                    <a class="nav-link" href="/users">
                        <i class="fas fa-users me-1"></i>Users
                    </a>
                    <a class="nav-link" href="/monitoring">
                        <i class="fas fa-chart-line me-1"></i>Monitoring
                    </a>
                    <a class="nav-link" href="/security">
                        <i class="fas fa-shield-alt me-1"></i>Security
                    </a>
                    <!-- Profile Dropdown -->
                    <div class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="profile-avatar-small">
                                <i class="fas fa-user"></i>
                            </div>
                            <span class="ms-2 d-none d-md-inline">Profile</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                            <li><a class="dropdown-item" href="/profile">
                                <i class="fas fa-user me-2"></i>Profile
                            </a></li>
                            <li><a class="dropdown-item" href="/settings">
                                <i class="fas fa-cog me-2"></i>Settings
                            </a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#" onclick="showLogoutConfirm()">
                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                            </a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
        
        <!-- Institutions Header -->
        <div class="container">
            <div class="institutions-header">
                <h1>Institution Management</h1>
                <div class="d-flex gap-2">
                    <button class="btn btn-institution" onclick="showCreateModal()">
                        <i class="fas fa-plus me-2"></i>Create Institution
                    </button>
                    <button class="btn btn-institution btn-outline" onclick="refreshInstitutions()">
                        <i class="fas fa-sync me-2"></i>Refresh
                    </button>
                </div>
            </div>
            
            <!-- Institutions List -->
            <div class="institutions-section">
                <h3 class="section-title">
                    <i class="fas fa-university me-2"></i>
                    All Institutions
                </h3>
                <div id="institutionsList">
                    <!-- Institutions will be loaded here -->
                </div>
            </div>
        </div>
    </div>
    
    <!-- Create Institution Modal -->
    <div class="modal fade" id="createInstitutionModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create New Institution</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="createAlert"></div>
                    <form id="createInstitutionForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control" id="institutionName" placeholder="Institution Name" required>
                                    <label for="institutionName">Institution Name</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control" id="institutionCode" placeholder="Institution Code" required>
                                    <label for="institutionCode">Institution Code</label>
                                </div>
                            </div>
                        </div>
                        <div class="form-floating mb-3">
                            <input type="email" class="form-control" id="institutionEmail" placeholder="Admin Email" required>
                            <label for="institutionEmail">Admin Email</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input type="tel" class="form-control" id="institutionPhone" placeholder="Phone Number">
                            <label for="institutionPhone">Phone Number</label>
                        </div>
                        <div class="form-floating mb-3">
                            <textarea class="form-control" id="institutionAddress" placeholder="Address" style="height: 100px;"></textarea>
                            <label for="institutionAddress">Address</label>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-institution" onclick="createInstitution()">
                        <i class="fas fa-plus me-2"></i>Create Institution
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Get user info from localStorage
        const userInfo = JSON.parse(localStorage.getItem('user_info') || '{}');
        const accessToken = localStorage.getItem('access_token');
        
        // Load institutions
        document.addEventListener('DOMContentLoaded', function() {
            loadInstitutions();
            
            // Check authentication
            if (!accessToken) {
                window.location.href = '/login';
            }
        });
        
        function loadInstitutions() {
            // Fetch institutions from backend
            fetch('/api/admin/institutions', {
                headers: {
                    'Authorization': `Bearer ${accessToken}`,
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    displayInstitutions(data.institutions);
                } else {
                    displayInstitutions([]);
                }
            })
            .catch(error => {
                console.error('Error loading institutions:', error);
                displayInstitutions([]);
            });
        }
        
        function displayInstitutions(institutions) {
            const container = document.getElementById('institutionsList');
            
            if (institutions.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-5">
                        <i class="fas fa-university fa-3x text-muted mb-3"></i>
                        <h4 class="text-muted">No institutions found</h4>
                        <p class="text-muted">Create your first institution to get started.</p>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = institutions.map(institution => `
                <div class="institution-card">
                    <div class="institution-header">
                        <div class="institution-name">${institution.name}</div>
                        <div class="institution-status ${institution.active ? 'status-active' : 'status-inactive'}">
                            ${institution.active ? 'Active' : 'Inactive'}
                        </div>
                    </div>
                    <div class="institution-details">
                        <div class="detail-item">
                            <span class="detail-label">Code:</span>
                            <span class="detail-value">${institution.code}</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Email:</span>
                            <span class="detail-value">${institution.email}</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Phone:</span>
                            <span class="detail-value">${institution.phone || 'N/A'}</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Created:</span>
                            <span class="detail-value">${new Date(institution.created_at).toLocaleDateString()}</span>
                        </div>
                    </div>
                    <div class="institution-actions">
                        <button class="btn btn-institution btn-sm" onclick="editInstitution('${institution.id}')">
                            <i class="fas fa-edit me-1"></i>Edit
                        </button>
                        <button class="btn btn-institution btn-sm" onclick="toggleInstitutionStatus('${institution.id}', ${!institution.active})">
                            <i class="fas fa-${institution.active ? 'pause' : 'play'} me-1"></i>
                            ${institution.active ? 'Deactivate' : 'Activate'}
                        </button>
                        <button class="btn btn-danger btn-sm" onclick="deleteInstitution('${institution.id}')">
                            <i class="fas fa-trash me-1"></i>Delete
                        </button>
                    </div>
                </div>
            `).join('');
        }
        
        function showCreateModal() {
            const modal = new bootstrap.Modal(document.getElementById('createInstitutionModal'));
            modal.show();
        }
        
        function createInstitution() {
            const form = document.getElementById('createInstitutionForm');
            const formData = {
                name: document.getElementById('institutionName').value,
                code: document.getElementById('institutionCode').value,
                email: document.getElementById('institutionEmail').value,
                phone: document.getElementById('institutionPhone').value,
                address: document.getElementById('institutionAddress').value
            };
            
            // Validate form
            if (!formData.name || !formData.code || !formData.email) {
                showAlert('createAlert', 'Please fill in all required fields', 'danger');
                return;
            }
            
            // Create institution
            fetch('/api/admin/institutions', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${accessToken}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(formData)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showAlert('createAlert', 'Institution created successfully!', 'success');
                    bootstrap.Modal.getInstance(document.getElementById('createInstitutionModal')).hide();
                    form.reset();
                    loadInstitutions();
                } else {
                    showAlert('createAlert', data.error || 'Failed to create institution', 'danger');
                }
            })
            .catch(error => {
                showAlert('createAlert', 'An error occurred. Please try again.', 'danger');
            });
        }
        
        function toggleInstitutionStatus(id, activate) {
            const action = activate ? 'activate' : 'deactivate';
            
            if (confirm(`Are you sure you want to ${action} this institution?`)) {
                fetch(`/api/admin/institutions/${id}/status`, {
                    method: 'PUT',
                    headers: {
                        'Authorization': `Bearer ${accessToken}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ active: activate })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        loadInstitutions();
                    } else {
                        alert(data.error || `Failed to ${action} institution`);
                    }
                })
                .catch(error => {
                    alert(`An error occurred while trying to ${action} institution`);
                });
            }
        }
        
        function deleteInstitution(id) {
            if (confirm('Are you sure you want to delete this institution? This action cannot be undone.')) {
                fetch(`/api/admin/institutions/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'Authorization': `Bearer ${accessToken}`
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        loadInstitutions();
                    } else {
                        alert(data.error || 'Failed to delete institution');
                    }
                })
                .catch(error => {
                    alert('An error occurred while trying to delete institution');
                });
            }
        }
        
        function editInstitution(id) {
            // Navigate to edit page or open edit modal
            alert(`Edit institution ${id} - Feature coming soon!`);
        }
        
        function refreshInstitutions() {
            loadInstitutions();
        }
        
        function showAlert(containerId, message, type) {
            const alertContainer = document.getElementById(containerId);
            alertContainer.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            
            // Auto-hide after 5 seconds
            setTimeout(() => {
                const alert = alertContainer.querySelector('.alert');
                if (alert) {
                    alert.remove();
                }
            }, 5000);
        }
        
        function showLogoutConfirm() {
            const modal = new bootstrap.Modal(document.getElementById('logoutModal'));
            modal.show();
        }
        
        function logout() {
            localStorage.removeItem('access_token');
            localStorage.removeItem('refresh_token');
            localStorage.removeItem('user_info');
            window.location.href = '/login';
        }
    </script>
    
    <!-- Logout Confirmation Modal -->
    <div class="modal fade" id="logoutModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Logout</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Do you really want to leave?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" onclick="logout()">OK</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
